// generator client {
//   provider = "prisma-client"
//   output   = "../src/generated/prisma"
// }
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  // New Profile Fields
  businessName String?
  phoneNumber  String?
  fax          String?
  city         String?
  state        String?
  country      String?
  postcode     String?
  avatarUrl    String?

  // Preferences & Notifications
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)
  autoPlayPromos     Boolean @default(true)
  themePreference    String  @default("dark")
  subscriptionTier   String  @default("Free")

  // Relations
  movies        Movie[]         @relation("MovieCreator")
  watchListItem WatchlistItem[]
  reviews       Review[]
}

model Movie {
  id          String          @id @default(uuid())
  title       String
  overview    String?
  releaseYear Int
  genres      String[]        @default([])
  runtime     Int?
  posterUrl   String?
  backdropUrl String?         // ✅ For cinematic hero banner
  trailerUrl  String?         // ✅ For trailer player
  rating      Float?          @default(0.0) // ✅ Dynamic rating
  isFeatured  Boolean         @default(false) // ✅ Explicitly pick hero movie
  createdBy   String
  updatedAt   DateTime        @updatedAt
  creator     User            @relation("MovieCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  watchItems  WatchlistItem[]
  reviews     Review[]
}

model WatchlistItem {
  id        String          @id @default(uuid())
  userId    String
  movieId   String
  status    WatchListStatus @default(PLANNED)
  rating    Int?
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  // Unique constraint: a user cannot add the same movie twice
  @@unique([userId, movieId], name: "unique_user_movie")
}

model Review {
  id        String   @id @default(uuid())
  rating    Int      // 1-10
  comment   String?
  userId    String
  movieId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  // A user can only leave one review per movie
  @@unique([userId, movieId])
}

enum WatchListStatus {
  PLANNED
  WATCHING
  COMPLETED
  DROPPED
}

enum Role {
  USER
  ADMIN
}
